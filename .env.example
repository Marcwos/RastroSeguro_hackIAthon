# RastroSeguro local configuration
# Copy to .env for local/demo use. Never commit real secrets.

# Optional OpenAI synthesis layer for the antifraud agent.
# The deterministic scoring/tools work without this.
OPENAI_API_KEY=
RASTRO_LLM_ENABLED=false
RASTRO_LLM_PROVIDER=openai
RASTRO_LLM_MODEL=gpt-4o
RASTRO_LLM_TIMEOUT_SECONDS=10
RASTRO_LLM_MAX_OUTPUT_TOKENS=700

# Comma-separated origins allowed by the FastAPI bridge for Next.js.
RASTRO_API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Illustrative prevention rate for savings simulation (PDF §10.2).
RASTRO_SAVINGS_PREVENTION_RATE=0.20
